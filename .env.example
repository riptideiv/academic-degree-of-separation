# Copy to .env.local for local dev (git-ignored). On Render, set these as
# service environment variables instead. All are optional — see README.md.
# load_dotenv uses override=False, so real env vars always take precedence.

# Free OpenAlex API key (recommended). OpenAlex retired the old "polite pool" in
# early 2025; a free key (openalex.org/settings/api) is now what raises your daily
# allowance (~$0.10/day keyless vs. ~$1/day with a key). Sent as the api_key param.
# OPENALEX_KEY=

# Your email. Formerly opted into OpenAlex's "polite pool" — now retired, so this
# no longer affects rate limits. Kept only as a courtesy identifier.
OPENALEX_MAILTO=you@example.com

# Graph source: "openalex" (default) or "bigquery".
# BACKEND=openalex

# GCP project for the BigQuery backend (only if BACKEND=bigquery).
# GOOGLE_CLOUD_PROJECT=

# Postgres connection string to persist the neighbor cache across restarts.
# Use the Supabase Supavisor *transaction* pooler URL — port 6543 (Project
# Settings → Database → Connection pooling, mode "Transaction"). Transaction mode
# multiplexes connections and scales to many more clients than session mode
# (port 5432, ~15-client cap on the free tier). Unset = falls back to
# neighbor_cache.json on the local filesystem.
# SUPABASE_DB_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Max asyncpg pool connections to Supabase (default 5). Keep small — the pooler's
# client budget is limited.
# SUPABASE_POOL_MAX=5

# Max neighbor-cache entries kept resident in memory (LRU). On a miss the entry
# is re-fetched from Supabase/JSON, so this bounds RAM, not correctness (default 10000).
# NEIGHBOR_CACHE_MAX=10000
